# ============================================================
#  Play Store upload signing — template
#
#  Copy this file to `keystore.properties` (same directory) and
#  fill in the real values. The real file is gitignored — it must
#  NEVER be committed.
#
#  Step-by-step:
#    cp android/keystore.properties.example android/keystore.properties
#    # then edit android/keystore.properties with your real values
#
#  The keystore file itself lives OUTSIDE the repo (recommended:
#  ~/secrets/vaultchat/vaultchat-upload.keystore). storeFile below
#  takes an absolute path.
#
#  If keystore.properties is missing, build.gradle falls back to
#  the debug keystore so debug builds still work — but `assembleRelease`
#  / `bundleRelease` will fail loudly, which is what we want.
# ============================================================

# Absolute path to the .keystore file. Tilde-expansion (~) is NOT
# supported by Gradle Properties — use the full path.
storeFile=/Users/YOUR_MAC_USERNAME/secrets/vaultchat/vaultchat-upload.keystore

# Password you set when running `keytool -genkeypair`.
storePassword=REPLACE_WITH_KEYSTORE_PASSWORD

# Alias supplied to keytool with `-alias` (we used vaultchat-upload).
keyAlias=vaultchat-upload

# Same as storePassword if you pressed RETURN at the key-password prompt.
keyPassword=REPLACE_WITH_KEY_PASSWORD
