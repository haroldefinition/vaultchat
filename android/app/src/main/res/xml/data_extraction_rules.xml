<?xml version="1.0" encoding="utf-8"?>
<!--
  VaultChat Data Extraction Rules (Android 12+).

  Replaces the older fullBackupContent for cloud backups, and also
  governs device-to-device transfers (e.g., when a user upgrades
  to a new phone via Google's Quick Setup wizard).

  Same posture as backup_rules.xml: with allowBackup="false" set
  in the manifest, neither cloud-backup nor device-transfer paths
  should run. These excludes are belt-and-suspenders so a future
  maintainer who flips allowBackup=true accidentally doesn't
  immediately leak the app's E2E state to Google Drive or to the
  user's next phone via the OS transfer wizard.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
