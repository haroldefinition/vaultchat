<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>AppGroupIdentifier</key>
    <string>group.com.chatvault.vaultchat</string>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>VaultChat</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.3</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleURLTypes</key>
    <array>
      <dict>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>vaultchat</string>
          <string>com.chatvault.vaultchat</string>
        </array>
      </dict>
      <dict>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>exp+vaultchat</string>
        </array>
      </dict>
    </array>
    <key>CFBundleVersion</key>
    <string>4</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
      <key>NSAllowsArbitraryLoads</key>
      <false/>
      <key>NSAllowsLocalNetworking</key>
      <true/>
    </dict>
    <key>ITSAppUsesNonExemptEncryption</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>VaultChat needs camera access to capture photos and videos for chats and to scan QR codes when adding contacts.</string>
    <key>NSContactsUsageDescription</key>
    <string>VaultChat needs contacts access to find people you already know who use VaultChat. Your contacts are matched on-device against our directory; we never upload your full address book.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>VaultChat uses Face ID to unlock locked chats and the Vault.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>VaultChat needs location access only when you tap the Share Location button in a chat. Location is never tracked in the background.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>VaultChat needs microphone access for voice and video calls.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>VaultChat needs to save photos to your library when you choose to download them.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>VaultChat needs access to your photos and videos to share them in chats.</string>
    <key>RCTNewArchEnabled</key>
    <true/>
    <key>UIBackgroundModes</key>
    <array>
      <string>audio</string>
      <string>voip</string>
    </array>
    <key>UILaunchStoryboardName</key>
    <string>SplashScreen</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
      <string>arm64</string>
    </array>
    <key>UIRequiresFullScreen</key>
    <false/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
      <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>
    <key>UIUserInterfaceStyle</key>
    <string>Dark</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
  </dict>
</plist>