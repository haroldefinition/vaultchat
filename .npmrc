# Phase AAA: required for EAS Android builds.
#
# expo-share-intent@6.1.0 declares peer expo@^55, but the project
# is on expo@54.x. The discrepancy is harmless in practice (the
# share-intent module works on Expo SDK 54), but npm 7+ refuses
# to install with a peer-dep conflict by default. EAS's build
# server runs `npm ci --include=dev` which is strict and fails
# the build. Setting legacy-peer-deps=true here matches the
# `--legacy-peer-deps` flag we use locally.
legacy-peer-deps=true
